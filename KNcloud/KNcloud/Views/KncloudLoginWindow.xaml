<base:WindowBase
    x:Class="KNcloud.Views.KncloudLoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:KNcloud.Base"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resx="clr-namespace:ServiceLib.Resx;assembly=ServiceLib"
    xmlns:vms="clr-namespace:ServiceLib.ViewModels;assembly=ServiceLib"
    Title="KNcloud 登录导入"
    Width="480"
    Height="320"
    x:TypeArguments="vms:KncloudLoginViewModel"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Style="{StaticResource WindowGlobal}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Border
        Margin="20"
        Padding="24"
        Background="{DynamicResource MaterialDesignPaper}"
        BorderBrush="{DynamicResource MaterialDesignDivider}"
        BorderThickness="1"
        CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock
                    FontSize="22"
                    FontWeight="SemiBold"
                    Text="KNcloud 登录导入" />
                <TextBlock
                    Margin="0,6,0,0"
                    Opacity="0.72"
                    Text="登录后将自动获取订阅链接并导入当前客户端。"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,24,0,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="邮箱" />
                <TextBox
                    x:Name="txtEmail"
                    Grid.Row="0"
                    Grid.Column="1"
                    Height="40"
                    VerticalContentAlignment="Center"
                    materialDesign:HintAssist.Hint="请输入邮箱"
                    Style="{StaticResource MyOutlinedTextBox}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="密码" />
                <PasswordBox
                    x:Name="txtPassword"
                    Grid.Row="2"
                    Grid.Column="1"
                    Height="40"
                    VerticalContentAlignment="Center"
                    materialDesign:HintAssist.Hint="请输入密码"
                    Style="{StaticResource MaterialDesignOutlinedPasswordBox}" />
            </Grid>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="btnLogin"
                    Grid.Row="0"
                    Grid.Column="0"
                    MinHeight="38"
                    Content="登录并导入"
                    IsDefault="True"
                    Style="{StaticResource DefButton}" />
                <Button
                    Grid.Row="0"
                    Grid.Column="2"
                    MinHeight="38"
                    Content="{x:Static resx:ResUI.TbCancel}"
                    IsCancel="true"
                    Style="{StaticResource DefButton}" />
                <Button
                    x:Name="btnForgetPassword"
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Center"
                    Content="忘记密码？"
                    Style="{StaticResource MaterialDesignFlatButton}" />
            </Grid>
        </Grid>
    </Border>
</base:WindowBase>