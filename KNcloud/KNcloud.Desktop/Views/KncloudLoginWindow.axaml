<Window
    x:Class="KNcloud.Desktop.Views.KncloudLoginWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resx="clr-namespace:ServiceLib.Resx;assembly=ServiceLib"
    xmlns:vms="clr-namespace:ServiceLib.ViewModels;assembly=ServiceLib"
    Title="KNcloud 登录导入"
    Width="480"
    Height="320"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Border
        Margin="20"
        Padding="24"
        Background="#1F1F23"
        BorderBrush="#333742"
        BorderThickness="1"
        CornerRadius="8">
        <Grid RowDefinitions="Auto,Auto,Auto">
            <StackPanel Grid.Row="0" Spacing="6">
                <TextBlock
                    FontSize="22"
                    FontWeight="SemiBold"
                    Text="KNcloud 登录导入" />
                <TextBlock
                    Opacity="0.72"
                    Text="登录后将自动获取订阅链接并导入当前客户端。"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Grid
                Grid.Row="1"
                Margin="0,24,0,18"
                ColumnDefinitions="70,*"
                RowDefinitions="Auto,14,Auto">
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="邮箱" />
                <TextBox
                    x:Name="txtEmail"
                    Grid.Row="0"
                    Grid.Column="1"
                    Height="40"
                    VerticalContentAlignment="Center"
                    Watermark="请输入邮箱" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="密码" />
                <TextBox
                    x:Name="txtPassword"
                    Grid.Row="2"
                    Grid.Column="1"
                    Height="40"
                    VerticalContentAlignment="Center"
                    PasswordChar="●"
                    Watermark="请输入密码" />
            </Grid>

            <Grid Grid.Row="2" RowDefinitions="Auto,Auto" ColumnDefinitions="*,12,*">
                <Button
                    x:Name="btnLogin"
                    Grid.Row="0"
                    Grid.Column="0"
                    MinHeight="38"
                    HorizontalAlignment="Stretch"
                    Content="登录并导入"
                    IsDefault="True" />
                <Button
                    x:Name="btnCancel"
                    Grid.Row="0"
                    Grid.Column="2"
                    MinHeight="38"
                    HorizontalAlignment="Stretch"
                    Content="{x:Static resx:ResUI.TbCancel}"
                    IsCancel="True" />
                <Button
                    x:Name="btnForgetPassword"
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Center"
                    Background="Transparent"
                    Content="忘记密码？" />
            </Grid>
        </Grid>
    </Border>
</Window>
